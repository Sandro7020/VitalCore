# MongoDB connection string
# Local:  mongodb://localhost:27017/
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=Cluster0
MONGO_URI=mongodb://localhost:27017/

# Database name
DB_NAME=vitalcore

# Server port
PORT=5000

# Skip connection ping on startup (set to "true" when SSL certs are unavailable,
# e.g. MSYS2/MinGW dev environments)
SKIP_PING=false
